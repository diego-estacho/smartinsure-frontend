# BFF → backend .NET (server-only, ADR-008). O browser NUNCA vê estes valores.
NUXT_BACKEND_BASE_URL=

# Dev-auth bypass para testes E2E (ADR-009) — NUNCA true em produção.
NUXT_DEV_AUTH_ENABLED=false

# Feature-flag da Fila de Revisão do Mapa de Modalidades (OPEN-14). Default oculta;
# true reexibe. Reativar só se o cadastro manual de Modalidades / exceções for decidido.
NUXT_PUBLIC_MODALITY_REVIEW_QUEUE=false
